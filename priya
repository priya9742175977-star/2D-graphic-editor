#include <math.h>

void clearPicture() {
int i, j;

for(i = 0; i < HEIGHT; i++) {  
    for(j = 0; j < WIDTH; j++) {  
        picture[i][j] = EMPTY;  
    }  
}

}

void displayPicture() {
int i, j;

for(i = 0; i < HEIGHT; i++) {  
    for(j = 0; j < WIDTH; j++) {  
        printf("%c", picture[i][j]);  
    }  
    printf("\n");  
}

}

void setPixel(int x, int y) {
if(x >= 0 && x < WIDTH && y >= 0 && y < HEIGHT) {
picture[y][x] = PIXEL;
}
}

